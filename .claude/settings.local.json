{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git init)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__figma__get_design_context",
      "mcp__figma__whoami",
      "Bash(firebase --version)",
      "Bash(npx firebase *)",
      "Bash(npm list *)",
      "Bash(npm root *)",
      "Bash(/Users/gerry-gutierrez/.nvm/versions/node/v18.0.0/bin/firebase *)",
      "Bash(python3 -m json.tool)",
      "Read(//Users/gerry-gutierrez/.claude/**)",
      "Bash(firebase login:list)",
      "Bash(firebase mcp *)",
      "Bash(gtimeout 5 firebase mcp)",
      "Bash(kill %1)",
      "mcp__plugin_firebase_firebase__firebase_create_project",
      "mcp__plugin_firebase_firebase__firebase_update_environment",
      "mcp__plugin_firebase_firebase__firebase_list_projects",
      "mcp__plugin_firebase_firebase__firebase_list_apps",
      "mcp__plugin_firebase_firebase__firebase_get_sdk_config",
      "Bash(npm view *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"File saved/edit!\"}'"
          },
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path'); [[ \"$fp\" =~ \\.tsx?$ ]] && npx prettier --write \"$fp\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
